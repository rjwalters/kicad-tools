	(text "MODE1	GND		(use external TCXO on SCK)\nMODE2	+3.3V	(DAC is master, generates BCK/LRCK from TCXO)\nXSMT	Float	(software mute control)\n"
		(exclude_from_sim no)
		(at 31.496 169.418 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left)
		)
		(uuid "74af106f-4917-4c99-ae19-a478c1dcaf44")
	)
	(text "PCM5122 Stereo Audio DAC\n\nI2S Interface:\n  - SCK (MCLK) = 24.576 MHz from TCXO\n  - BCK, LRCK, DIN from Raspberry Pi\n\nOutput Stage:\n  - 470R + 2.2nF RC filter per TI app note\n  - Ground-centered output (no DC blocking caps)\n\nI2C Address: 0x4C (ADR1=L, ADR2=L)"
		(exclude_from_sim no)
		(at 24.638 36.322 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left)
		)
		(uuid "90672797-78f8-4558-a532-f8e453fd349f")
	)
