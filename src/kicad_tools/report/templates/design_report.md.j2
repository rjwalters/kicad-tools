### Action Items

{% for item in audit.action_items %}
- **[{{ {1: 'CRITICAL', 2: 'IMPORTANT', 3: 'OPTIONAL'}.get(item.priority, 'INFO') }}]** {{ item.description }}
{% if item.command %}  `{{ item.command }}`
{% endif %}
{% endfor %}
{% endif %}

{% endif %}
